@using System.Globalization
@model Cinema_Management.Models.ConcessionsViewModel

@{
    ViewData["Title"] = "POS Concessions Register";
    var culture = new CultureInfo("vi-VN");
    var formMode = ViewBag.ConcessionFormMode as string;
    var showForm = formMode == "create" || formMode == "edit";
    var isEdit = formMode == "edit";
}

<header class="staff-header">
    <div style="display:flex;align-items:center;gap:16px;">
        <h2>QUAN LY BAP NUOC</h2>
        <span class="badge badge-outline">DANG KET NOI</span>
    </div>
    <div style="display:flex;gap:12px;">
        <a class="btn-primary" asp-controller="Staff" asp-action="CreateConcession" title="Them mon">+ Them mon</a>
        <button class="btn-secondary" style="border:none;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
            LUU
        </button>
    </div>
</header>

<div class="concessions-layout">
    <div class="concessions-main">
        <div class="pos-stats">
            <div class="stat-card">
                <p class="stat-label">LOI NHUAN DOANH THU HANG NGAY</p>
                <h3>0 VND</h3>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-400)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline><polyline points="16 7 22 7 22 13"></polyline></svg>
            </div>
            <div class="stat-card">
                <p class="stat-label">TONG SO GIAO DICH</p>
                <h3>0 GIAO DICH</h3>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-400)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
            </div>
            <div class="stat-card">
                <p class="stat-label">GIA TRI TRUNG BINH MOI DON</p>
                <h3>0 VND</h3>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-400)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
            </div>
        </div>

        <div class="category-tabs" data-concession-tabs>
            <button class="tab-btn active" type="button" data-category="all">Tat ca</button>
            <button class="tab-btn" type="button" data-category="Drinks">Drinks</button>
            <button class="tab-btn" type="button" data-category="Popcorn">Popcorn</button>
            <button class="tab-btn" type="button" data-category="Combos">Combos</button>
        </div>

        <div class="concessions-grid">
            @if (!Model.Items.Any())
            {
                <div class="concessions-empty">Chua co mon bap nuoc nao trong database.</div>
            }

            @foreach (var item in Model.Items)
            {
                var price = item.ComboPrice.ToString("N0", culture) + " VND";
                var dataPrice = item.ComboPrice.ToString(CultureInfo.InvariantCulture);

                <div class="concession-item concession-card"
                     draggable="true"
                     data-combo-id="@item.ComboID"
                     data-combo-name="@item.ComboName"
                     data-combo-price="@dataPrice"
                     data-category="all">
                    <div class="item-img-wrap concession-placeholder" aria-hidden="true">
                        <span>@GetPlaceholderText(item.ComboName)</span>
                    </div>
                    <div class="item-info">
                        <div class="item-header">
                            <h4>@item.ComboName</h4>
                            <span class="item-price">@price</span>
                        </div>
                        <div class="concession-actions">
                            <a class="btn-edit-concession"
                               asp-controller="Staff"
                               asp-action="EditConcession"
                               asp-route-id="@item.ComboID"
                               title="Sua mon"
                               aria-label="Sua mon @item.ComboName">Sua</a>
                            <button class="btn-add" type="button">THEM VAO GIO</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="receipt-sidebar">
        <div class="receipt-header">
            <h4>GIO HANG</h4>
            <span class="badge badge-primary">POS READY</span>
        </div>

        <div id="cartDropZone" class="cart-drop-zone">
            Keo mon vao day de them vao gio
        </div>

        <div id="cartItems" class="receipt-cart-items"></div>

        <div class="receipt-footer">
            <div class="receipt-total">
                <span>Tong gia tri (Da tinh thue)</span>
                <strong id="cartTotal">0 VND</strong>
            </div>
            <div class="receipt-actions">
                <button id="resetCartButton" class="btn-secondary" style="flex:1" type="button">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><polyline points="3 3 3 8 8 8"></polyline></svg>
                    LAM MOI
                </button>
                <button class="btn-primary" style="flex:2;justify-content:center">THANH TOAN</button>
            </div>
        </div>
    </div>
</div>

@if (showForm)
{
    <div class="modal-backdrop show">
        <div class="modal-dialog">
            <div class="modal-header">
                <div>
                    <p class="modal-pretitle">Bap nuoc</p>
                    <h3>@(isEdit ? "Sua mon" : "Them mon")</h3>
                </div>
                <a class="btn-close-modal" asp-controller="Staff" asp-action="Concessions" aria-label="Dong">×</a>
            </div>
            <form asp-controller="Staff" asp-action="@(isEdit ? "EditConcession" : "CreateConcession")" method="post">
                <input type="hidden" asp-for="Form.ComboID" name="ComboID" />
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="form-group">
                        <label for="ComboName">Ten mon</label>
                        <input id="ComboName" name="ComboName" value="@Model.Form.ComboName" maxlength="150" />
                        @Html.ValidationMessage("ComboName", null, new { @class = "text-danger" })
                    </div>
                    <div class="form-group">
                        <label for="ComboPrice">Gia mon</label>
                        <input id="ComboPrice" name="ComboPrice" value="@Model.Form.ComboPrice" type="number" min="0.01" step="1000" />
                        @Html.ValidationMessage("ComboPrice", null, new { @class = "text-danger" })
                    </div>
                </div>
                <div class="modal-footer">
                    <a class="btn-secondary btn-close-modal" asp-controller="Staff" asp-action="Concessions">Huy</a>
                    <button class="btn-primary" type="submit">@(isEdit ? "Cap nhat" : "Them mon")</button>
                </div>
            </form>
        </div>
    </div>
}

@functions {
    private static string GetPlaceholderText(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 0)
        {
            return "CB";
        }

        return string.Concat(parts.Take(2).Select(part => char.ToUpperInvariant(part[0])));
    }
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // UI-only category mapping.
        // Categories are not stored in the database.
        const concessionCategoryMap = {
            1: "Popcorn",
            2: "Popcorn",
            3: "Drinks",
            4: "Drinks",
            5: "Drinks",
            6: "Combos",
            7: "Combos",
            8: "Combos",
            9: "Combos",
            10: "Combos",
            11: "Combos",
            12: "Combos",
            13: "Combos"
        };

        let cart = [];
        const cards = document.querySelectorAll('.concession-card');
        const cartDropZone = document.getElementById('cartDropZone');
        const cartItems = document.getElementById('cartItems');
        const cartTotal = document.getElementById('cartTotal');
        const resetCartButton = document.getElementById('resetCartButton');

        cards.forEach(function (card) {
            const comboId = Number(card.dataset.comboId);
            card.dataset.category = concessionCategoryMap[comboId] ?? "Combos";

            card.addEventListener('dragstart', function (event) {
                const product = getProductFromCard(card);
                event.dataTransfer.setData('application/json', JSON.stringify(product));
                event.dataTransfer.effectAllowed = 'copy';
            });
        });

        document.querySelectorAll('[data-concession-tabs] .tab-btn').forEach(function (button) {
            button.addEventListener('click', function () {
                var category = button.dataset.category;
                document.querySelectorAll('[data-concession-tabs] .tab-btn').forEach(function (tab) {
                    tab.classList.toggle('active', tab === button);
                });
                cards.forEach(function (card) {
                    const shouldShow = category === 'all' || card.dataset.category === category;
                    card.hidden = !shouldShow;
                });
            });
        });

        document.querySelectorAll('.btn-add').forEach(function (button) {
            button.addEventListener('click', function () {
                const card = button.closest('.concession-card');
                if (!card) {
                    return;
                }

                addToCart(getProductFromCard(card));
            });
        });

        cartDropZone.addEventListener('dragenter', function (event) {
            event.preventDefault();
            cartDropZone.classList.add('is-drag-over');
        });

        cartDropZone.addEventListener('dragover', function (event) {
            event.preventDefault();
            event.dataTransfer.dropEffect = 'copy';
            cartDropZone.classList.add('is-drag-over');
        });

        cartDropZone.addEventListener('dragleave', function () {
            cartDropZone.classList.remove('is-drag-over');
        });

        cartDropZone.addEventListener('drop', function (event) {
            event.preventDefault();
            cartDropZone.classList.remove('is-drag-over');

            const rawProduct = event.dataTransfer.getData('application/json');
            if (!rawProduct) {
                return;
            }

            try {
                addToCart(JSON.parse(rawProduct));
            } catch {
                return;
            }
        });

        cartItems.addEventListener('click', function (event) {
            const button = event.target.closest('[data-cart-action]');
            if (!button) {
                return;
            }

            const comboId = Number(button.dataset.comboId);
            if (button.dataset.cartAction === 'increase') {
                increaseQuantity(comboId);
            } else if (button.dataset.cartAction === 'decrease') {
                decreaseQuantity(comboId);
            } else if (button.dataset.cartAction === 'remove') {
                removeFromCart(comboId);
            }
        });

        resetCartButton.addEventListener('click', function () {
            cart = [];
            renderCart();
        });

        function getProductFromCard(card) {
            return {
                comboId: Number(card.dataset.comboId),
                comboName: card.dataset.comboName || '',
                comboPrice: Number(card.dataset.comboPrice)
            };
        }

        function addToCart(product) {
            const existingItem = cart.find(function (item) {
                return item.comboId === product.comboId;
            });

            if (existingItem) {
                existingItem.quantity += 1;
            } else {
                cart.push({
                    comboId: product.comboId,
                    comboName: product.comboName,
                    comboPrice: product.comboPrice,
                    quantity: 1
                });
            }

            renderCart();
        }

        function increaseQuantity(comboId) {
            const item = cart.find(function (cartItem) {
                return cartItem.comboId === comboId;
            });

            if (item) {
                item.quantity += 1;
                renderCart();
            }
        }

        function decreaseQuantity(comboId) {
            const item = cart.find(function (cartItem) {
                return cartItem.comboId === comboId;
            });

            if (!item) {
                return;
            }

            item.quantity -= 1;
            if (item.quantity <= 0) {
                removeFromCart(comboId);
                return;
            }

            renderCart();
        }

        function removeFromCart(comboId) {
            cart = cart.filter(function (item) {
                return item.comboId !== comboId;
            });
            renderCart();
        }

        function renderCart() {
            cartItems.replaceChildren();

            if (cart.length === 0) {
                const emptyMessage = document.createElement('div');
                emptyMessage.className = 'cart-empty-compact';
                emptyMessage.textContent = 'Chua co mon trong gio';
                cartItems.appendChild(emptyMessage);
                cartTotal.textContent = formatVnd(0);
                return;
            }

            cart.forEach(function (item) {
                const row = document.createElement('div');
                row.className = 'cart-line-item';

                const name = document.createElement('strong');
                name.className = 'cart-line-name';
                name.textContent = item.comboName;

                const meta = document.createElement('span');
                meta.className = 'cart-line-meta';
                meta.textContent = formatVnd(item.comboPrice) + ' x ' + item.quantity;

                const subtotal = document.createElement('span');
                subtotal.className = 'cart-line-subtotal';
                subtotal.textContent = 'Thanh tien: ' + formatVnd(item.comboPrice * item.quantity);

                const controls = document.createElement('div');
                controls.className = 'cart-line-controls';

                const decrease = createCartButton('-', 'decrease', item.comboId);
                const quantity = document.createElement('span');
                quantity.className = 'cart-line-quantity';
                quantity.textContent = item.quantity.toString();
                const increase = createCartButton('+', 'increase', item.comboId);
                const remove = createCartButton('Xoa', 'remove', item.comboId);

                controls.append(decrease, quantity, increase, remove);
                row.append(name, meta, subtotal, controls);
                cartItems.appendChild(row);
            });

            cartTotal.textContent = formatVnd(calculateTotal());
        }

        function createCartButton(text, action, comboId) {
            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'cart-control-btn';
            button.dataset.cartAction = action;
            button.dataset.comboId = comboId.toString();
            button.textContent = text;
            return button;
        }

        function calculateTotal() {
            return cart.reduce(function (sum, item) {
                return sum + item.comboPrice * item.quantity;
            }, 0);
        }

        function formatVnd(value) {
            return new Intl.NumberFormat('vi-VN').format(value) + ' VND';
        }

        renderCart();
    </script>
}
