@section Scripts {
    <script>
        const editorModal = document.getElementById('movieEditorModal');
        const createModal = document.getElementById('movieCreateModal');
        const btnAddMovie = document.getElementById('btnAddMovie');
        const scheduleDateInput = document.getElementById('scheduleDate');
        const btnSaveSchedule = document.getElementById('btnSaveSchedule');
        const movieSearchInput = document.getElementById('movieSearchInput');
        const movieSearchEmpty = document.getElementById('movieSearchEmpty');
        const scheduleStartHour = 8;
        const scheduleEndHour = 23;
        const scheduleTotalMinutes = (scheduleEndHour - scheduleStartHour) * 60;
        const scheduleSnapMinutes = 15;
        const scheduleDefaultBasePrice = 90000;
        
        const closeBtns = document.querySelectorAll('.btn-close-modal');
        const editBtns = document.querySelectorAll('.edit-movie-btn');
        const telemetryText = document.querySelector('.telemetry p');

        function setTelemetry(message) {
            if (telemetryText) {
                telemetryText.textContent = `TELEMETRY LOGS: ${message}`;
            }
        }

        function getMoviePayload(item) {
            return {
                movieId: Number(item.dataset.movieId),
                title: item.dataset.title || '',
                duration: Number(item.dataset.duration || 0)
            };
        }

        function normalizeText(value) {
            return (value || '')
                .toLowerCase()
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .replace(/đ/g, 'd')
                .replace(/\s+/g, ' ')
                .trim();
        }

        function filterMoviesByName() {
            const keyword = normalizeText(movieSearchInput?.value);
            let visibleCount = 0;

            document.querySelectorAll('.movie-list-item').forEach(item => {
                const title = normalizeText(item.dataset.title);
                const genre = normalizeText(item.dataset.genre);
                const titleMatches = title.includes(keyword);
                const genreMatches = !titleMatches && genre.includes(keyword);
                const isVisible = !keyword || titleMatches || genreMatches;
                item.classList.toggle('is-search-hidden', !isVisible);
                item.draggable = isVisible;

                if (isVisible) {
                    visibleCount++;
                }
            });

            if (movieSearchEmpty) {
                movieSearchEmpty.hidden = visibleCount > 0;
            }

            if (keyword) {
                setTelemetry(`Tim thay ${visibleCount} phim phu hop.`);
            }
        }

        function minutesToTime(minutesFromStart) {
            const totalMinutes = scheduleStartHour * 60 + minutesFromStart;
            const hours = Math.floor(totalMinutes / 60);
            const minutes = totalMinutes % 60;
            return `${String(hours).padStart(2, '0')}:${String(minutes).padStart(2, '0')}`;
        }

        function timeToMinutes(time) {
            const parts = time.split(':').map(Number);
            return ((parts[0] * 60) + parts[1]) - (scheduleStartHour * 60);
        }

        function clockTimeToMinutes(time) {
            const parts = time.split(':').map(Number);
            return (parts[0] * 60) + parts[1];
        }

        function clampStart(startMinutes, duration) {
            return Math.max(0, Math.min(startMinutes, scheduleTotalMinutes - duration));
        }

        function createScheduleBlock({ showtimeId, movieId, title, duration, startMinutes, basePrice }) {
            const block = document.createElement('div');
            const safeDuration = Math.max(duration || scheduleSnapMinutes, scheduleSnapMinutes);
            const safeStart = clampStart(startMinutes, safeDuration);

            block.className = 'schedule-block';
            block.dataset.showtimeId = showtimeId || '';
            block.dataset.movieId = movieId;
            block.dataset.duration = safeDuration;
            block.dataset.startTime = minutesToTime(safeStart);
            block.dataset.endTime = minutesToTime(safeStart + safeDuration);
            block.dataset.basePrice = basePrice || scheduleDefaultBasePrice;
            block.style.left = `${(safeStart / scheduleTotalMinutes) * 100}%`;
            block.style.width = `${(safeDuration / scheduleTotalMinutes) * 100}%`;
            block.innerHTML = `
                <button type="button" class="schedule-block-remove" title="Xoa lich">&times;</button>
                <span class="schedule-block-title"></span>
                <span class="schedule-block-time"></span>
            `;
            block.querySelector('.schedule-block-title').textContent = title;
            block.querySelector('.schedule-block-time').textContent = `${block.dataset.startTime} - ${block.dataset.endTime}`;
            block.querySelector('.schedule-block-remove').addEventListener('click', () => block.remove());
            return block;
        }

        function addScheduleBlock(timeline, movie, startMinutes) {
            const resolvedMovieId = movie.movieId ?? movie.movieID ?? movie.MovieID;
            const block = createScheduleBlock({
                showtimeId: movie.showtimeId ?? movie.showtimeID ?? movie.ShowtimeID,
                movieId: resolvedMovieId,
                title: movie.title,
                duration: movie.duration,
                basePrice: movie.basePrice,
                startMinutes
            });
            timeline.appendChild(block);
        }

        function getDropStartMinutes(timeline, event, duration) {
            const rect = timeline.getBoundingClientRect();
            const ratio = Math.max(0, Math.min(1, (event.clientX - rect.left) / rect.width));
            const rawMinutes = ratio * scheduleTotalMinutes;
            const snapped = Math.round(rawMinutes / scheduleSnapMinutes) * scheduleSnapMinutes;
            return clampStart(snapped, duration);
        }

        function timelineHasOverlap(timeline, startMinutes, endMinutes, ignoredBlock = null) {
            return Array.from(timeline.querySelectorAll('.schedule-block')).some(block => {
                if (block === ignoredBlock) {
                    return false;
                }

                const blockStart = timeToMinutes(block.dataset.startTime);
                const blockEnd = timeToMinutes(block.dataset.endTime);
                return startMinutes < blockEnd && endMinutes > blockStart;
            });
        }

        function getSchedulePayloadItems() {
            return Array.from(document.querySelectorAll('.mr-timeline')).flatMap(timeline =>
                Array.from(timeline.querySelectorAll('.schedule-block')).map(block => ({
                    ShowtimeID: Number(block.dataset.showtimeId || 0),
                    MovieID: Number(block.dataset.movieId),
                    RoomID: Number(timeline.dataset.roomId || timeline.dataset.hallNumber),
                    Date: scheduleDateInput.value,
                    StartTime: buildScheduleDateTime(block.dataset.startTime),
                    EndTime: buildScheduleDateTime(block.dataset.endTime),
                    BasePrice: Number(block.dataset.basePrice || scheduleDefaultBasePrice),
                    _startMinutes: timeToMinutes(block.dataset.startTime),
                    _endMinutes: timeToMinutes(block.dataset.endTime)
                }))
            );
        }

        function findInvalidScheduleItem(items) {
            return items.find(item =>
                !Number.isInteger(item.MovieID) || item.MovieID <= 0 ||
                !Number.isInteger(item.RoomID) || item.RoomID <= 0 ||
                !Number.isFinite(item.BasePrice) || item.BasePrice <= 0 ||
                item._endMinutes <= item._startMinutes
            );
        }

        function findOverlappingScheduleItem(items) {
            const grouped = items.reduce((map, item) => {
                if (!map.has(item.RoomID)) {
                    map.set(item.RoomID, []);
                }
                map.get(item.RoomID).push(item);
                return map;
            }, new Map());

            for (const roomItems of grouped.values()) {
                const ordered = roomItems.slice().sort((a, b) => a._startMinutes - b._startMinutes);
                for (let i = 1; i < ordered.length; i++) {
                    if (ordered[i - 1]._endMinutes > ordered[i]._startMinutes) {
                        return ordered[i];
                    }
                }
            }

            return null;
        }

        document.querySelectorAll('.movie-list-item').forEach(item => {
            item.addEventListener('dragstart', event => {
                if (event.target.closest('.ml-actions')) {
                    event.preventDefault();
                    return;
                }

                event.dataTransfer.setData('application/json', JSON.stringify(getMoviePayload(item)));
                event.dataTransfer.effectAllowed = 'copy';
            });
        });

        movieSearchInput?.addEventListener('input', filterMoviesByName);
        filterMoviesByName();

        document.querySelectorAll('.mr-timeline').forEach(timeline => {
            timeline.addEventListener('dragover', event => {
                event.preventDefault();
                timeline.classList.add('drag-over');
            });

            timeline.addEventListener('dragleave', () => timeline.classList.remove('drag-over'));

            timeline.addEventListener('drop', event => {
                event.preventDefault();
                timeline.classList.remove('drag-over');

                const payload = event.dataTransfer.getData('application/json');
                if (!payload) {
                    return;
                }

                const movie = JSON.parse(payload);
                const startMinutes = getDropStartMinutes(timeline, event, movie.duration);
                const endMinutes = startMinutes + Math.max(movie.duration || scheduleSnapMinutes, scheduleSnapMinutes);
                if (timelineHasOverlap(timeline, startMinutes, endMinutes)) {
                    setTelemetry('Lich chieu bi trung gio trong cung phong chieu.');
                    return;
                }

                addScheduleBlock(timeline, movie, startMinutes);
                setTelemetry(`Da them "${movie.title}" vao phong chieu ${timeline.dataset.roomId || timeline.dataset.hallNumber}.`);
            });
        });

        async function loadSchedule() {
            document.querySelectorAll('.schedule-block').forEach(block => block.remove());

            const response = await fetch(`/Staff/GetSchedule?date=${encodeURIComponent(scheduleDateInput.value)}`);
            if (!response.ok) {
                setTelemetry('Khong tai duoc lich chieu.');
                return;
            }

            const showtimes = await response.json();
            showtimes.forEach(showtime => {
                const roomId = showtime.roomId || showtime.roomID || showtime.hallNumber;
                const timeline = document.querySelector(`.mr-timeline[data-room-id="${roomId}"], .mr-timeline[data-hall-number="${roomId}"]`);
                if (!timeline) {
                    return;
                }

                addScheduleBlock(timeline, {
                    showtimeId: showtime.showtimeId ?? showtime.showtimeID ?? showtime.ShowtimeID,
                    movieId: showtime.movieId ?? showtime.movieID ?? showtime.MovieID,
                    title: showtime.movieTitle,
                    duration: showtime.duration,
                    basePrice: showtime.basePrice
                }, timeToMinutes(showtime.startTime));
            });

            setTelemetry(`Da tai ${showtimes.length} suat chieu.`);
        }

        function buildScheduleDateTime(time) {
            return `${scheduleDateInput.value}T${time}:00`;
        }

        async function readScheduleResponse(response) {
            const text = await response.text();
            if (!text) {
                return {};
            }

            try {
                return JSON.parse(text);
            } catch {
                return {
                    message: `Server tra ve phan hoi khong phai JSON (${response.status}).`,
                    detail: text.slice(0, 300)
                };
            }
        }

        async function saveSchedule() {
            const payloadItems = getSchedulePayloadItems();
            const invalidItem = findInvalidScheduleItem(payloadItems);
            if (invalidItem) {
                setTelemetry(`Du lieu lich chieu khong hop le: MovieID=${invalidItem.MovieID}, RoomID=${invalidItem.RoomID}, BasePrice=${invalidItem.BasePrice}.`);
                return;
            }

            const overlapItem = findOverlappingScheduleItem(payloadItems);
            if (overlapItem) {
                setTelemetry(`Lich chieu bi trung gio trong phong ${overlapItem.RoomID}.`);
                return;
            }

            const items = payloadItems.map(({ _startMinutes, _endMinutes, ...item }) => item);

            const response = await fetch('/Staff/SaveSchedule', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    Date: scheduleDateInput.value,
                    Items: items
                })
            });

            const result = await readScheduleResponse(response);
            if (!response.ok) {
                const details = result.errors
                    ? Object.entries(result.errors)
                        .map(([field, messages]) => `${field}: ${messages.join(', ')}`)
                        .join(' | ')
                    : result.detail || '';
                setTelemetry(details ? `${result.message}: ${details}` : result.message || 'Luu lich that bai.');
                return;
            }

            setTelemetry(`${result.message} (${result.count} suat chieu, them ${result.created || 0}, cap nhat ${result.updated || 0}, xoa ${result.deleted || 0})`);
            await loadSchedule();
        }

        btnSaveSchedule.addEventListener('click', saveSchedule);
        scheduleDateInput.addEventListener('change', loadSchedule);
        loadSchedule();

        btnAddMovie.addEventListener('click', () => {
            createModal.classList.add('show');
        });

        // Live Poster Preview logic
        document.getElementById('createPosterInput').addEventListener('input', function() {
            const preview = document.getElementById('createPosterPreview');
            const placeholder = document.getElementById('createPosterPlaceholder');
            if (this.value) {
                preview.src = this.value;
                preview.style.display = 'block';
                placeholder.style.display = 'none';
            } else {
                preview.src = '';
                preview.style.display = 'none';
                placeholder.style.display = 'block';
            }
        });

        document.getElementById('editPoster').addEventListener('input', function() {
            const preview = document.getElementById('editPosterPreview');
            const placeholder = document.getElementById('editPosterPlaceholder');
            if (this.value) {
                preview.src = this.value;
                preview.style.display = 'block';
                placeholder.style.display = 'none';
            } else {
                preview.src = '';
                preview.style.display = 'none';
                placeholder.style.display = 'block';
            }
        });
        
        // Event delegation — bắt click trên toàn bộ movies-list
        const moviesList = document.querySelector('.movies-list');
        editBtns.forEach(btn =>{
            btn.addEventListener('click', (e) => {
                const editBtn = e.target.closest('.edit-movie-btn');
                
                const item = editBtn.closest('.movie-list-item');
                if (item) {
                    document.getElementById('editMovieID').value = item.dataset.movieId || '';
                    document.getElementById('editTitle').value = item.dataset.title || '';
                    document.getElementById('editDuration').value = item.dataset.duration || '';
                    document.getElementById('editSynopsis').value = item.dataset.synopsis || '';
                    document.getElementById('editTrailer').value = item.dataset.trailer || '';
                    document.getElementById('editPoster').value = item.dataset.poster || '';
                    document.getElementById('editGenre').value = item.dataset.genre || '';
                    document.getElementById('editReleaseDate').value = item.dataset.releaseDate || '';
                    // trigger input event to show image
                    document.getElementById('editPoster').dispatchEvent(new Event('input'));
                    
                    const rating = item.dataset.rating || '';
                    const select = document.getElementById('editRating');
                    for (let i = 0; i < select.options.length; i++) {
                        if (select.options[i].value === rating) {
                            select.selectedIndex = i;
                            break;
                        }
                    }
                }
                editorModal.classList.add('show');
            });
        });

        closeBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                editorModal.classList.remove('show');
                createModal.classList.remove('show');
            });
        });
        
        // Format tag toggle
        document.querySelectorAll('.format-tag').forEach(tag => {
            tag.addEventListener('click', function() {
                this.classList.toggle('active');
            });
        });
    </script>
}
