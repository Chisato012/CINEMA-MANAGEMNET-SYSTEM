@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.ActiveNav = "home";
}

<div class="space-y-8">
    <!-- Welcome Header -->
    <div class="border-b border-outline-variant/30 pb-6 mb-8">
        <h2 class="font-display-lg text-5xl font-bold tracking-tighter mb-2">Chào mừng trở lại</h2>
        <p class="text-on-surface-variant text-base">Bạn đang đăng nhập với tài khoản: <span class="text-primary font-mono font-bold">@ViewBag.AdminEmail</span></p>
    </div>

    <!-- Quick Stats Overview -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <!-- Quick Card 1 -->
        <a href="/Admin/Analytics" class="bg-surface-container border border-outline-variant/30 rounded-xl p-8 cinematic-glow shadow-[0_10px_40px_-10px_rgba(0,0,0,0.8)] relative overflow-hidden group hover:border-primary/50 transition-colors duration-500 no-underline">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-primary/10 rounded-full blur-3xl group-hover:bg-primary/20 transition-all duration-500 pointer-events-none"></div>
            <div class="flex items-center gap-4 relative z-10">
                <div class="bg-surface-variant p-3 rounded-lg border border-outline-variant/50">
                    <span class="material-symbols-outlined text-primary">analytics</span>
                </div>
                <div>
                    <div class="font-display-lg text-on-surface text-xl font-bold">Phân tích doanh thu</div>
                    <div class="font-mono text-xs text-on-surface-variant mt-1">Xem thống kê kinh doanh</div>
                </div>
            </div>
            <div class="flex items-center gap-2 mt-6 relative z-10">
                <span class="material-symbols-outlined text-primary text-sm">arrow_forward</span>
                <span class="font-mono text-xs text-primary">Xem chi tiết</span>
            </div>
        </a>

        <!-- Quick Card 2 -->
        <a href="/Admin/Staff" class="bg-surface-container border border-outline-variant/30 rounded-xl p-8 cinematic-glow shadow-[0_10px_40px_-10px_rgba(0,0,0,0.8)] relative overflow-hidden group hover:border-secondary/50 transition-colors duration-500 no-underline">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-secondary/10 rounded-full blur-3xl group-hover:bg-secondary/20 transition-all duration-500 pointer-events-none"></div>
            <div class="flex items-center gap-4 relative z-10">
                <div class="bg-surface-variant p-3 rounded-lg border border-outline-variant/50">
                    <span class="material-symbols-outlined text-secondary">badge</span>
                </div>
                <div>
                    <div class="font-display-lg text-on-surface text-xl font-bold">Quản lý nhân viên</div>
                    <div class="font-mono text-xs text-on-surface-variant mt-1">Quản lý tài khoản Staff</div>
                </div>
            </div>
            <div class="flex items-center gap-2 mt-6 relative z-10">
                <span class="material-symbols-outlined text-secondary text-sm">arrow_forward</span>
                <span class="font-mono text-xs text-secondary">Xem chi tiết</span>
            </div>
        </a>

        <!-- Quick Card 3 -->
        <a href="/Admin/Settings" class="bg-surface-container border border-outline-variant/30 rounded-xl p-8 cinematic-glow shadow-[0_10px_40px_-10px_rgba(0,0,0,0.8)] relative overflow-hidden group hover:border-tertiary/50 transition-colors duration-500 no-underline">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-tertiary/10 rounded-full blur-3xl group-hover:bg-tertiary/20 transition-all duration-500 pointer-events-none"></div>
            <div class="flex items-center gap-4 relative z-10">
                <div class="bg-surface-variant p-3 rounded-lg border border-outline-variant/50">
                    <span class="material-symbols-outlined text-tertiary">settings</span>
                </div>
                <div>
                    <div class="font-display-lg text-on-surface text-xl font-bold">Cài đặt hệ thống</div>
                    <div class="font-mono text-xs text-on-surface-variant mt-1">Cấu hình & hồ sơ</div>
                </div>
            </div>
            <div class="flex items-center gap-2 mt-6 relative z-10">
                <span class="material-symbols-outlined text-tertiary text-sm">arrow_forward</span>
                <span class="font-mono text-xs text-tertiary">Xem chi tiết</span>
            </div>
        </a>
    </div>

    <!-- System Info -->
    <div class="bg-surface-container border border-outline-variant/30 rounded-xl p-8 cinematic-glow shadow-[0_10px_40px_-10px_rgba(0,0,0,0.8)]">
        <h3 class="font-display-lg text-2xl text-on-surface tracking-tight mb-4">Thông tin hệ thống</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 font-mono text-sm">
            <div class="flex justify-between border-b border-outline-variant/20 pb-3">
                <span class="text-on-surface-variant">Phiên bản</span>
                <span class="text-primary">Cosmos Cinema v2.0</span>
            </div>
            <div class="flex justify-between border-b border-outline-variant/20 pb-3">
                <span class="text-on-surface-variant">Trạng thái hệ thống</span>
                <span class="text-primary">● Online</span>
            </div>
            <div class="flex justify-between border-b border-outline-variant/20 pb-3">
                <span class="text-on-surface-variant">Vai trò</span>
                <span class="text-tertiary">Administrator</span>
            </div>
            <div class="flex justify-between border-b border-outline-variant/20 pb-3">
                <span class="text-on-surface-variant">Email</span>
                <span class="text-on-surface">@ViewBag.AdminEmail</span>
            </div>
        </div>
    </div>
</div>
