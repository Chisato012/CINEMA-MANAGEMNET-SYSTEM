@model Cinema_Management.Models.AdminAnalyticsViewModel
@{
    ViewData["Title"] = "Phân tích doanh thu";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.ActiveNav = "analytics";

    var maxRevenue = Model.RevenueByMonth.Any()
        ? Model.RevenueByMonth.Max(x => x.Revenue)
        : 0m;
}

<div class="space-y-8">
    <!-- Header -->
    <div class="flex flex-col xl:flex-row justify-between items-start xl:items-end border-b border-outline-variant/30 pb-6 mb-8 gap-6">
        <div>
            <h2 class="font-display-lg text-5xl font-bold tracking-tighter mb-2">Phân tích kinh doanh</h2>
            <p class="text-on-surface-variant text-base">Theo dõi doanh thu, số vé bán ra và hiệu suất phim.</p>
        </div>

        <!-- Filter theo tháng và phim -->
        <form method="get" asp-controller="Admin" asp-action="Analytics" class="flex flex-wrap gap-4">
            <div class="relative">
                <select name="month"
                        onchange="this.form.submit()"
                        class="cinematic-input font-mono text-sm px-4 py-2.5 pr-10 rounded-t bg-transparent text-on-surface appearance-none cursor-pointer min-w-[180px] focus:outline-none focus:ring-0">
                    <option value="">Tất cả tháng</option>
                    @foreach (var item in Model.Months)
                    {
                        <option value="@item.Value" selected="@(item.Value == Model.SelectedMonth ? "selected" : null)">
                            @item.Text
                        </option>
                    }
                </select>
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-on-surface-variant">calendar_month</span>
            </div>

            <div class="relative">
                <select name="movieId"
                        onchange="this.form.submit()"
                        class="cinematic-input font-mono text-sm px-4 py-2.5 pr-10 rounded-t bg-transparent text-on-surface appearance-none cursor-pointer min-w-[240px] focus:outline-none focus:ring-0">
                    <option value="">Tất cả phim</option>
                    @foreach (var movie in Model.Movies)
                    {
                        <option value="@movie.MovieId" selected="@(movie.MovieId == Model.SelectedMovieId ? "selected" : null)">
                            @movie.Title
                        </option>
                    }
                </select>
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-on-surface-variant">movie</span>
            </div>
        </form>
    </div>

    <!-- KPI Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 mb-8">
        <div class="bg-surface-container border border-outline-variant/30 rounded-xl p-7 cinematic-glow shadow-[0_10px_40px_-10px_rgba(0,0,0,0.8)] relative overflow-hidden group hover:border-primary/50 transition-colors duration-500">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-primary/10 rounded-full blur-3xl group-hover:bg-primary/20 transition-all duration-500 pointer-events-none"></div>
            <div class="flex justify-between items-start gap-4 relative z-10">
                <div>
                    <div class="font-mono text-[10px] text-on-surface-variant mb-2 uppercase tracking-wider">Tổng doanh thu</div>
                    <div class="font-display-lg text-on-surface text-4xl font-bold leading-none">
                        @Model.TotalRevenue.ToString("N0")
                    </div>
                    <div class="font-mono text-xs text-on-surface-variant mt-2">VNĐ</div>
                </div>
                <div class="bg-surface-variant p-3 rounded-lg border border-outline-variant/50 shrink-0">
                    <span class="material-symbols-outlined text-primary">account_balance_wallet</span>
                </div>
            </div>
        </div>

        <div class="bg-surface-container border border-outline-variant/30 rounded-xl p-7 cinematic-glow shadow-[0_10px_40px_-10px_rgba(0,0,0,0.8)] relative overflow-hidden group hover:border-primary/50 transition-colors duration-500">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-secondary/10 rounded-full blur-3xl group-hover:bg-secondary/20 transition-all duration-500 pointer-events-none"></div>
            <div class="flex justify-between items-start gap-4 relative z-10">
                <div>
                    <div class="font-mono text-[10px] text-on-surface-variant mb-2 uppercase tracking-wider">Tổng số vé bán ra</div>
                    <div class="font-display-lg text-on-surface text-4xl font-bold leading-none">
                        @Model.TotalTicketsSold.ToString("N0")
                    </div>
                    <div class="font-mono text-xs text-on-surface-variant mt-2">Vé</div>
                </div>
                <div class="bg-surface-variant p-3 rounded-lg border border-outline-variant/50 shrink-0">
                    <span class="material-symbols-outlined text-secondary">local_activity</span>
                </div>
            </div>
        </div>

        <div class="bg-surface-container border border-outline-variant/30 rounded-xl p-7 cinematic-glow shadow-[0_10px_40px_-10px_rgba(0,0,0,0.8)] relative overflow-hidden group hover:border-primary/50 transition-colors duration-500">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-tertiary/10 rounded-full blur-3xl group-hover:bg-tertiary/20 transition-all duration-500 pointer-events-none"></div>
            <div class="flex justify-between items-start gap-4 relative z-10">
                <div>
                    <div class="font-mono text-[10px] text-on-surface-variant mb-2 uppercase tracking-wider">Booking đã thanh toán</div>
                    <div class="font-display-lg text-on-surface text-4xl font-bold leading-none">
                        @Model.ConfirmedBookings.ToString("N0")
                    </div>
                    <div class="font-mono text-xs text-on-surface-variant mt-2">Đơn</div>
                </div>
                <div class="bg-surface-variant p-3 rounded-lg border border-outline-variant/50 shrink-0">
                    <span class="material-symbols-outlined text-tertiary">confirmation_number</span>
                </div>
            </div>
        </div>

        <div class="bg-surface-container border border-outline-variant/30 rounded-xl p-7 cinematic-glow shadow-[0_10px_40px_-10px_rgba(0,0,0,0.8)] relative overflow-hidden group hover:border-primary/50 transition-colors duration-500">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-primary/10 rounded-full blur-3xl group-hover:bg-primary/20 transition-all duration-500 pointer-events-none"></div>
            <div class="flex justify-between items-start gap-4 relative z-10">
                <div>
                    <div class="font-mono text-[10px] text-on-surface-variant mb-2 uppercase tracking-wider">Doanh thu / vé</div>
                    <div class="font-display-lg text-on-surface text-4xl font-bold leading-none">
                        @Model.AverageRevenuePerTicket.ToString("N0")
                    </div>
                    <div class="font-mono text-xs text-on-surface-variant mt-2">VNĐ / vé</div>
                </div>
                <div class="bg-surface-variant p-3 rounded-lg border border-outline-variant/50 shrink-0">
                    <span class="material-symbols-outlined text-primary">payments</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Revenue Chart -->
    <div class="bg-surface-container border border-outline-variant/30 rounded-xl p-8 cinematic-glow shadow-[0_10px_40px_-10px_rgba(0,0,0,0.8)]">
        <div class="flex flex-col md:flex-row md:justify-between md:items-center gap-4 mb-8">
            <div>
                <h3 class="font-display-lg text-2xl text-on-surface tracking-tight">Doanh thu theo tháng</h3>
                <p class="font-mono text-xs text-on-surface-variant mt-1">Tổng hợp từ các payment thành công của booking đã xác nhận</p>
            </div>

            @if (Model.SelectedMonth != null || Model.SelectedMovieId != null)
            {
                <a asp-controller="Admin"
                   asp-action="Analytics"
                   class="inline-flex items-center gap-2 text-on-surface-variant hover:text-primary transition-colors no-underline font-mono text-xs">
                    <span class="material-symbols-outlined text-[18px]">filter_alt_off</span>
                    Xóa bộ lọc
                </a>
            }
        </div>

        @if (Model.RevenueByMonth.Any())
        {
            <div class="h-80 w-full flex items-end justify-between gap-4 pt-6 border-b border-outline-variant/40 pb-2 relative font-mono text-xs text-on-surface-variant/70 overflow-x-auto">
                <div class="absolute inset-0 flex flex-col justify-between pointer-events-none pb-2 min-w-full">
                    <div class="w-full border-t border-[#353534] border-dashed"></div>
                    <div class="w-full border-t border-[#353534] border-dashed"></div>
                    <div class="w-full border-t border-[#353534] border-dashed"></div>
                    <div class="w-full border-t border-[#353534] border-dashed"></div>
                    <div class="w-full"></div>
                </div>

                @foreach (var item in Model.RevenueByMonth)
                {
                    var barHeight = maxRevenue == 0m
                        ? 0
                        : Math.Max(12, (int)Math.Round(item.Revenue / maxRevenue * 230));

                    <div class="min-w-[90px] flex-1 flex flex-col items-center group z-10">
                        <div class="text-xs font-bold text-primary opacity-0 group-hover:opacity-100 transition-opacity duration-300 mb-2 whitespace-nowrap">
                            @item.Revenue.ToString("N0") VNĐ
                        </div>
                        <div class="w-12 bg-gradient-to-t from-primary/10 to-primary/80 border-t-2 border-primary rounded-t transition-all duration-300 group-hover:brightness-110"
                             style="height: @(barHeight)px;"></div>
                        <span class="mt-3 text-xs whitespace-nowrap">@item.Label</span>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="h-64 flex flex-col items-center justify-center border border-dashed border-outline-variant/40 rounded-lg text-center">
                <span class="material-symbols-outlined text-on-surface-variant mb-3 text-4xl">analytics</span>
                <p class="font-mono text-sm text-on-surface-variant">Chưa có dữ liệu doanh thu cho bộ lọc hiện tại.</p>
            </div>
        }
    </div>

    <!-- Data Summary -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="bg-surface-container border border-outline-variant/30 rounded-xl p-8 cinematic-glow shadow-[0_10px_40px_-10px_rgba(0,0,0,0.8)]">
            <h3 class="font-display-lg text-2xl text-on-surface tracking-tight mb-6">Chi tiết doanh thu</h3>

            @if (Model.RevenueByMonth.Any())
            {
                <div class="space-y-4">
                    @foreach (var item in Model.RevenueByMonth.OrderByDescending(x => x.Year).ThenByDescending(x => x.Month).Take(6))
                    {
                        var percent = maxRevenue == 0m
                            ? 0
                            : Math.Max(4, (int)Math.Round(item.Revenue / maxRevenue * 100));

                        <div>
                            <div class="flex justify-between gap-4 mb-2 font-mono text-xs">
                                <span class="text-on-surface-variant">@item.Label</span>
                                <span class="text-on-surface">@item.Revenue.ToString("N0") VNĐ</span>
                            </div>
                            <div class="h-2 bg-surface-variant rounded-full overflow-hidden">
                                <div class="h-full bg-primary rounded-full" style="width: @(percent)%;"></div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="font-mono text-sm text-on-surface-variant">Chưa có dữ liệu để hiển thị.</p>
            }
        </div>

        <div class="bg-surface-container border border-outline-variant/30 rounded-xl p-8 cinematic-glow shadow-[0_10px_40px_-10px_rgba(0,0,0,0.8)]">
            <h3 class="font-display-lg text-2xl text-on-surface tracking-tight mb-6">Bộ lọc hiện tại</h3>

            <div class="space-y-4 font-mono text-sm">
                <div class="flex justify-between gap-4 border-b border-outline-variant/30 pb-3">
                    <span class="text-on-surface-variant">Tháng</span>
                    <span class="text-on-surface text-right">
                        @(Model.Months.FirstOrDefault(x => x.Value == Model.SelectedMonth)?.Text ?? "Tất cả tháng")
                    </span>
                </div>
                <div class="flex justify-between gap-4 border-b border-outline-variant/30 pb-3">
                    <span class="text-on-surface-variant">Phim</span>
                    <span class="text-on-surface text-right">
                        @(Model.Movies.FirstOrDefault(x => x.MovieId == Model.SelectedMovieId)?.Title ?? "Tất cả phim")
                    </span>
                </div>
                <div class="flex justify-between gap-4 border-b border-outline-variant/30 pb-3">
                    <span class="text-on-surface-variant">Doanh thu</span>
                    <span class="text-on-surface text-right">@Model.TotalRevenue.ToString("N0") VNĐ</span>
                </div>
                <div class="flex justify-between gap-4">
                    <span class="text-on-surface-variant">Vé bán ra</span>
                    <span class="text-on-surface text-right">@Model.TotalTicketsSold.ToString("N0") vé</span>
                </div>
            </div>
        </div>
    </div>
</div>
