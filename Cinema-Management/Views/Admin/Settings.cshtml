@model Cinema_Management.Models.User
@{
    ViewData["Title"] = "Cài đặt";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.ActiveNav = "settings";
}

<div class="space-y-8">
    <div class="flex justify-between items-end border-b border-outline-variant/30 pb-6 mb-8">
        <div>
            <h2 class="font-display-lg text-5xl font-bold tracking-tighter mb-2">Cài đặt</h2>
            <p class="text-on-surface-variant text-base">Cài đặt tài khoản cho Admin.</p>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-8 mb-12">
        <!-- Profile Setup -->
        <form method="post" asp-controller="Admin" asp-action="UpdateSettings" class="bg-surface-container border border-outline-variant/30 rounded-xl p-8 cinematic-glow shadow-2xl relative overflow-hidden mw-100">
            @Html.AntiForgeryToken()
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-primary/5 rounded-full blur-3xl pointer-events-none"></div>
            <h3 class="font-display-lg text-2xl flex items-center gap-3 mb-8 text-on-surface">
                <span class="material-symbols-outlined text-primary">person</span>
                Cài đặt trang cá nhân
            </h3>
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="rounded-lg border border-primary/30 bg-primary/10 px-4 py-3 text-sm text-primary mb-4">
                    @TempData["SuccessMessage"]
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="rounded-lg border border-error/30 bg-error/10 px-4 py-3 text-sm text-error mb-4">
                @TempData["ErrorMessage"]
            </div>
        }
            <div class="space-y-6 relative z-10">
                <div class="flex items-center gap-6 mb-8">
                    <div class="w-16 h-16 rounded-full bg-surface-variant overflow-hidden border border-outline-variant flex items-center justify-center">
                        <span class="material-symbols-outlined text-3xl text-on-surface-variant">person</span>
                    </div>
                    <button class="text-primary text-sm hover:text-primary/80 transition-colors font-mono text-xs uppercase tracking-wider">Đổi hình nền</button>
                </div>
                @* Nhận data truyền từ controller *@

                <div class="relative">
                    <label class="block font-mono text-xs text-on-surface-variant mb-1 uppercase tracking-widest">Tên</label>
                    <input type="text" name="FullName" value="@Model.FullName" class="w-full cinematic-input px-0 py-2 text-on-surface focus:outline-none" />
                </div>
                <div class="relative">
                    <label class="block font-mono text-xs text-on-surface-variant mb-1 uppercase tracking-widest">Email</label>
                    <input type="email" name="Email" value="@Model.Email" class="w-full cinematic-input px-0 py-2 text-on-surface focus:outline-none" />
                </div>
                <div class="relative pt-4">
                    <label class="block font-mono text-xs text-on-surface-variant mb-1 uppercase tracking-widest">Mật khẩu cũ</label>
                    <input type="password" name="Password" class="w-full cinematic-input px-0 py-2 text-on-surface placeholder:text-on-surface-variant/30 focus:outline-none" />
                </div>
                <div class="relative pt-4">
                    <label class="block font-mono text-xs text-on-surface-variant mb-1 uppercase tracking-widest">Mật khẩu mới</label>
                    <input type="password" name="newPassword" class="w-full cinematic-input px-0 py-2 text-on-surface placeholder:text-on-surface-variant/30 focus:outline-none" />
                </div>
                <div class="pt-6 flex justify-end">
                    <button type="submit" class="px-6 py-2 rounded font-mono text-xs bg-primary-container text-on-primary-container cinematic-glow hover:bg-inverse-primary transition-colors shadow-md">
                    Cập nhật tài khoản
                    </button>
                </div>
            </div>
        </form>

    </div>
</div>
