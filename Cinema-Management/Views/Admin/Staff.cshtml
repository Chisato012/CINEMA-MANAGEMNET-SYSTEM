@model IEnumerable<Cinema_Management.Models.User>
@{
    ViewData["Title"] = "Quản lý nhân viên";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.ActiveNav = "staff";
}
<style>
    .staff-page-fade {
        animation: staffFadeIn 180ms ease-out;
    }

    @@keyframes staffFadeIn {
        from {
            opacity: 0;
            transform: translateY(6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="space-y-8">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b border-outline-variant/30 pb-6 mb-8 gap-4">
        <div>
            <h2 class="font-display-lg text-5xl font-bold tracking-tighter mb-2">Quản lý nhân viên</h2>
            <p class="text-on-surface-variant text-base">Cosmos Cinema quản lý</p>
        </div>
        <button onclick="toggleModal(true)" class="bg-primary-container text-on-primary-container font-mono text-sm px-6 py-2.5 rounded-lg flex items-center gap-2 cinematic-glow hover:bg-inverse-primary transition-all duration-300 shadow-lg cursor-pointer">
            <span class="material-symbols-outlined text-lg">person_add</span>
            Thêm tài khoản nhân viên
        </button>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="rounded-lg border border-primary/30 bg-primary/10 px-4 py-3 text-sm text-primary">
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="rounded-lg border border-error/30 bg-error/10 px-4 py-3 text-sm text-error">
            @TempData["ErrorMessage"]
        </div>
    }

    <!-- Filters Area -->
    <div class="mb-6 flex flex-wrap gap-4">
        <div class="relative w-full max-w-sm">
            <input type="text" placeholder="Tìm kiếm..." class="w-full cinematic-input px-0 py-2 text-on-surface placeholder:text-on-surface-variant/30 focus:outline-none" />
        </div>
        <div class="relative">
            <select class="cinematic-input px-0 py-2 pr-8 min-w-[150px] text-on-surface bg-transparent focus:outline-none cursor-pointer appearance-none">
                <option value="" class="bg-surface-container">Vai trò</option>
                <option value="manager" class="bg-surface-container">Admin</option>
                <option value="staff" class="bg-surface-container">Staff</option>
            </select>
            <span class="material-symbols-outlined absolute right-0 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none">arrow_drop_down</span>
        </div>
    </div>

    <!-- Data Table -->
    <div class="bg-surface-container-low rounded-xl border border-outline-variant/30 overflow-hidden shadow-2xl cinematic-glow">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse min-w-[800px]">
                <thead>
                    <tr class="border-b border-outline-variant/40 bg-surface-container/50">
                        <th class="py-4 px-6 font-mono text-xs text-on-surface-variant uppercase tracking-wider">Staff ID</th>
                        <th class="py-4 px-6 font-mono text-xs text-on-surface-variant uppercase tracking-wider">Full Name</th>
                        <th class="py-4 px-6 font-mono text-xs text-on-surface-variant uppercase tracking-wider">Email</th>
                        <th class="py-4 px-6 font-mono text-xs text-on-surface-variant uppercase tracking-wider">Phone</th>
                        <th class="py-4 px-6 font-mono text-xs text-on-surface-variant uppercase tracking-wider">Status</th>
                        <th class="py-4 px-6 font-mono text-xs text-on-surface-variant uppercase tracking-wider text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-outline-variant/20 staff-page-fade">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var staff in Model)
                        {
                            <tr class="hover:bg-surface-variant/20 transition-colors @(staff.Status ? "" : "opacity-60")">
                                <td class="py-4 px-6 font-mono text-sm text-tertiary">EMP-@staff.UserID.ToString("D3")</td>
                                <td class="py-4 px-6 flex items-center gap-3">
                                    @{
                                        var nameParts = string.IsNullOrWhiteSpace(staff.FullName) 
                                            ? new string[] { "N", "A" } 
                                            : staff.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                                        var initials = nameParts.Length > 1 
                                            ? $"{nameParts[0][0]}{nameParts[^1][0]}".ToUpper() 
                                            : (nameParts.Length > 0 ? nameParts[0][0].ToString().ToUpper() : "ST");
                                        var textClass = staff.Status ? "text-primary" : "text-on-surface-variant";
                                    }
                                    <div class="w-8 h-8 rounded-full bg-surface-container-high flex items-center justify-center text-xs font-bold border border-outline-variant/50 @textClass">@initials</div>
                                    @staff.FullName
                                </td>
                                <td class="py-4 px-6 text-on-surface-variant">@staff.Email</td>
                                <td class="py-4 px-6 font-mono text-sm">@(string.IsNullOrWhiteSpace(staff.PhoneNumber) ? "N/A" : staff.PhoneNumber)</td>
                                <td class="py-4 px-6">
                                    @if (staff.Status)
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border bg-primary/10 text-primary border-primary/20">
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border bg-surface-variant text-on-surface-variant border-outline-variant">
                                            Off-Duty
                                        </span>
                                    }
                                </td>
                                <td class="py-4 px-6 text-right space-x-1">
                                    <button class="text-on-surface-variant hover:text-primary transition-colors p-1" title="Toggle Duty"><span class="material-symbols-outlined text-[20px]">swap_horiz</span></button>
                                    <button type="button"
                                            class="text-on-surface-variant hover:text-primary transition-colors p-1"
                                            title="Edit Staff"
                                            data-user-id="@staff.UserID"
                                            data-full-name="@staff.FullName"
                                            data-email="@staff.Email"
                                            data-phone-number="@staff.PhoneNumber"
                                            data-dob="@(staff.DOB?.ToString("yyyy-MM-dd") ?? "")"
                                            data-status="@staff.Status.ToString().ToLowerInvariant()"
                                            data-role="@staff.Role"
                                            onclick="openEditStaffModal(this)">
                                        <span class="material-symbols-outlined text-[20px]">edit</span>
                                    </button> 
                                    @* Thêm sự kiện cho button sửa *@
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="py-4 px-6 text-center text-on-surface-variant">Không có nhân viên nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Table Footer Pagination -->
        @{
            var currentPage = ViewBag.CurrentPage as int? ?? 1; //trang hiện tại
            var totalPages = ViewBag.TotalPages as int? ?? 1; //tổng số trang
            var totalCount = ViewBag.TotalCount as int? ?? 0; //tổng số nhân viên

            var hasPreviousPage = currentPage > 1; //có trang trước ?
            var hasNextPage = currentPage < totalPages; //có trang tiếp ?
        }
        <div class="p-4 border-t border-outline-variant/30 flex flex-col sm:flex-row justify-between items-center bg-surface-container/30 gap-4">
            <span class="font-mono text-xs text-on-surface-variant">
                Tổng số @ViewBag.TotalCount nhân viên
                @if(totalPages > 0)
                {
                    <span> - Trang @currentPage / @totalPages</span>
                }
            </span>
            <div class="flex gap-2">
                @if (hasPreviousPage)
                {
                    <a asp-controller="Admin" asp-action="Staff" asp-route-page="@(currentPage - 1)"class="px-3 py-1 rounded border border-outline-variant/50 text-on-surface-variant hover:text-on-surface hover:border-outline-variant transition-colors font-mono text-xs">
                        Prev
                        @* trừ đi 1 page ở current page *@
                    </a>
                }
                else
                {
                    <button disabled class="px-3 py-1 rounded border border-outline-variant/50 text-on-surface-variant font-mono text-xs cursor-not-allowed opacity-50">
                        Prev
                    </button>
                }

                @if (hasNextPage) 
                @* nếu có trang tiếp *@
                {
                    <a asp-controller="Admin" asp-action="Staff" asp-route-page="@(currentPage + 1)" class="px-3 py-1 rounded border border-outline-variant/50 text-on-surface-variant hover:text-on-surface hover:border-outline-variant transition-colors font-mono text-xs">
                        Next
                    </a>

                }
                else
                {
                    <button disabled class="px-3 py-1 rounded border border-outline-variant/50 text-on-surface-variant font-mono text-xs cursor-not-allowed opacity-50">
                        Next
                    </button>
                }
            </div>
        </div>
    </div>
</div>

<!-- EDIT STAFF modal  -->
<div id="editStaffModal" class="fixed inset-0 z-50 flex items-center justify-center p-4 hidden">
    <div class="absolute inset-0 bg-background/80 backdrop-blur-sm" onclick="toggleEditModal(false)"></div>
    <div class="relative bg-surface-container w-full rounded-xl border border-outline-variant shadow-[0_20px_50px_rgba(0,0,0,0.5)] cinematic-glow overflow-hidden z-10" style="width: 800px;">
        <div class="absolute top-0 right-0 w-32 h-32 bg-secondary/10 rounded-full blur-3xl pointer-events-none"></div>

        <div class="px-6 py-5 border-b border-outline-variant/30 flex justify-between items-center">
            <h3 class="font-display-lg text-xl text-on-surface">Chỉnh sửa tài khoản nhân viên</h3>
            <button onclick="toggleEditModal(false)" class="text-on-surface-variant hover:text-white transition-colors" aria-label="Close modal">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        @* form sửa tài khoản *@
        <form class="p-6 space-y-5" method="post" asp-controller="Admin" asp-action="UpdateStaff">
            @Html.AntiForgeryToken()
            <input type="hidden" id="editUserID" name="UserID" />
            <input type="hidden" name="page" value="@ViewBag.CurrentPage" />

            <div class="relative">
                <label class="block font-mono text-xs text-on-surface-variant mb-1 uppercase tracking-wider">Tên</label>
                <input type="text" id="editFullName" name="FullName" placeholder="Họ và tên" class="w-full cinematic-input px-0 py-2 text-on-surface focus:outline-none" required />
            </div>
            <div class="relative">
                <label class="block font-mono text-xs text-on-surface-variant mb-1 uppercase tracking-wider">Email</label>
                <input type="email" id="editEmail" name="Email" placeholder="name@cosmos.com" class="w-full cinematic-input px-0 py-2 text-on-surface focus:outline-none" required />
            </div>
            <div class="relative">
                <label class="block font-mono text-xs text-on-surface-variant mb-1 uppercase tracking-wider">SĐT</label>
                <input type="tel" id="editPhoneNumber" name="PhoneNumber" placeholder="0901234567" class="w-full cinematic-input px-0 py-2 text-on-surface focus:outline-none" />
            </div>
            <div class="relative">
                <label class="block font-mono text-xs text-on-surface-variant mb-1 uppercase tracking-wider">Mật khẩu mới</label>
                <input type="password" id="editPasswordHash" name="PasswordHash" placeholder="Để trống nếu không đổi mật khẩu" class="w-full cinematic-input px-0 py-2 text-on-surface focus:outline-none" />
            </div>
            <div class="relative">
                <label class="block font-mono text-xs text-on-surface-variant mb-1 uppercase tracking-wider">Ngày sinh</label>
                <input type="date" id="editDOB" name="DOB" class="w-full cinematic-input px-0 py-2 text-on-surface focus:outline-none" />
            </div>
            <div class="relative">
                <label class="block font-mono text-xs text-on-surface-variant mb-1 uppercase tracking-wider">Trạng thái</label>
                <div class="relative">
                    <select id="editStatus" name="Status" class="w-full cinematic-input px-0 py-2 bg-transparent text-on-surface focus:outline-none cursor-pointer appearance-none">
                        <option value="true" class="bg-surface-container text-on-surface-variant">Active</option>
                        <option value="false" class="bg-surface-container text-on-surface-variant">Off-Duty</option>
                    </select>
                    <span class="material-symbols-outlined absolute right-0 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none">arrow_drop_down</span>
                </div>
            </div>
            <div class="relative">
                <label class="block font-mono text-xs text-on-surface-variant mb-1 uppercase tracking-wider">Vai trò</label>
                <div class="relative">
                    <select id="editRole" name="Role" class="w-full cinematic-input px-0 py-2 bg-transparent text-on-surface focus:outline-none cursor-pointer appearance-none" required>
                        <option value="Admin" class="bg-surface-container">Admin</option>
                        <option value="Staff" class="bg-surface-container">Staff</option>
                    </select>
                    <span class="material-symbols-outlined absolute right-0 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none">arrow_drop_down</span>
                </div>
            </div>
            <div class="pt-4 flex justify-end gap-3 mt-4 border-t border-outline-variant/30">
                <button type="button" onclick="toggleEditModal(false)" class="px-5 py-2 font-mono text-xs text-on-surface-variant border border-outline-variant rounded hover:bg-surface-variant transition-colors">
                    Huỷ
                </button>
                <button type="submit" class="px-6 py-2 rounded font-mono text-xs bg-primary-container text-on-primary-container cinematic-glow hover:bg-inverse-primary transition-colors shadow-md">
                    Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ADD STAFF MODAL OVERLAY -->
<div id="addStaffModal" class="fixed inset-0 z-50 flex items-center justify-center p-4 hidden">
    <div class="absolute inset-0 bg-background/80 backdrop-blur-sm" onclick="toggleModal(false)"></div>
    <div class="relative bg-surface-container w-full max-w rounded-xl border border-outline-variant shadow-[0_20px_50px_rgba(0,0,0,0.5)] cinematic-glow overflow-hidden z-10" style="width: 800px;">
        <div class="absolute top-0 right-0 w-32 h-32 bg-primary/10 rounded-full blur-3xl pointer-events-none"></div>

        <div class="px-6 py-5 border-b border-outline-variant/30 flex justify-between items-center">
            <h3 class="font-display-lg text-xl text-on-surface">Đăng ký tài khoản nhân viên</h3>
            <button onclick="toggleModal(false)" class="text-on-surface-variant hover:text-white transition-colors" aria-label="Close modal">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <form class="p-6 space-y-5" method="post" action="/Admin/CreateStaff">
            <div class="relative">
                <label class="block font-mono text-xs text-on-surface-variant mb-1 uppercase tracking-wider">Tên</label>
                <input type="text" name="FullName" placeholder="Họ và tên" class="w-full cinematic-input px-0 py-2 text-on-surface focus:outline-none" required />
            </div>
            <div class="relative">
                <label class="block font-mono text-xs text-on-surface-variant mb-1 uppercase tracking-wider">Email</label>
                <input type="email" name="Email" placeholder="name@cosmos.com" class="w-full cinematic-input px-0 py-2 text-on-surface focus:outline-none" required />
            </div>
            <div class="relative">
                <label class="block font-mono text-xs text-on-surface-variant mb-1 uppercase tracking-wider">SĐT</label>
                <input type="tel" name="PhoneNumber" placeholder="0901234567" class="w-full cinematic-input px-0 py-2 text-on-surface focus:outline-none" />
            </div>
            <div class="relative">
                <label class="block font-mono text-xs text-on-surface-variant mb-1 uppercase tracking-wider">Mật khẩu</label>
                <input type="password" name="PasswordHash" placeholder="Nhập mật khẩu" class="w-full cinematic-input px-0 py-2 text-on-surface focus:outline-none" required />
            </div>
            <div class="relative">
                <label class="block font-mono text-xs text-on-surface-variant mb-1 uppercase tracking-wider">Ngày sinh</label>
                <input type="date" name="DOB" class="w-full cinematic-input px-0 py-2 text-on-surface focus:outline-none" />
            </div>
            <div class="relative">
                <label class="block font-mono text-xs text-on-surface-variant mb-1 uppercase tracking-wider">Trạng thái</label>
                <div class="relative">
                    <select name="Status" class="w-full cinematic-input px-0 py-2 bg-transparent text-on-surface focus:outline-none cursor-pointer appearance-none">
                        <option value="true" class="bg-surface-container text-on-surface-variant">Active</option>
                        <option value="false" class="bg-surface-container text-on-surface-variant">Off-Duty</option>
                    </select>
                    <span class="material-symbols-outlined absolute right-0 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none">arrow_drop_down</span>
                </div>
            </div>
            <div class="relative">
                <label class="block font-mono text-xs text-on-surface-variant mb-1 uppercase tracking-wider">Vai trò</label>
                <div class="relative">
                    <select name="Role" class="w-full cinematic-input px-0 py-2 bg-transparent text-on-surface focus:outline-none cursor-pointer appearance-none" required>
                        <option value="" class="bg-surface-container text-on-surface-variant">Chọn vai trò</option>
                        <option value="Admin" class="bg-surface-container">Admin</option>
                        <option value="Staff" class="bg-surface-container">Staff</option>
                    </select>
                    <span class="material-symbols-outlined absolute right-0 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none">arrow_drop_down</span>
                </div>
            </div>
            <div class="pt-4 flex justify-end gap-3 mt-4 border-t border-outline-variant/30">
                <button type="button" onclick="toggleModal(false)" class="px-5 py-2 font-mono text-xs text-on-surface-variant border border-outline-variant rounded hover:bg-surface-variant transition-colors">
                    Huỷ
                </button>
                <button type="submit" class="px-6 py-2 rounded font-mono text-xs bg-primary-container text-on-primary-container cinematic-glow hover:bg-inverse-primary transition-colors shadow-md">
                    Tạo tài khoản
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function toggleModal(show) {
            const modal = document.getElementById('addStaffModal');
            if (show) {
                modal.classList.remove('hidden');
            } else {
                modal.classList.add('hidden');
            }
        }

        function toggleEditModal(show) {
            const modal = document.getElementById('editStaffModal');
            if (show) {
                modal.classList.remove('hidden');
            } else {
                modal.classList.add('hidden');
            }
        }

        function openEditStaffModal(button) {
            const data = button.dataset;
            document.getElementById('editUserID').value = data.userId || '';
            document.getElementById('editFullName').value = data.fullName || '';
            document.getElementById('editEmail').value = data.email || '';
            document.getElementById('editPhoneNumber').value = data.phoneNumber || '';
            document.getElementById('editDOB').value = data.dob || '';
            document.getElementById('editStatus').value = data.status === 'false' ? 'false' : 'true';
            document.getElementById('editRole').value = data.role || 'Staff';
            document.getElementById('editPasswordHash').value = '';
            toggleEditModal(true);
        }


    </script>
}
