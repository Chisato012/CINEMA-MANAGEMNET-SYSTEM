<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Cosmos Cinema Admin</title>

    <!-- Google Fonts and Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Narrow:wght@400;600;700&family=Manrope:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1" rel="stylesheet">

    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
        theme: {
        extend: {
        colors: {
        background: '#131313',
        'on-surface': '#e5e2e1',
        'on-surface-variant': '#d5c3b8',
        primary: '#f4bb92',
        'primary-container': '#8b5e3c',
        'on-primary-container': '#ffe3d1',
        'surface-container': '#201f1f',
        'surface-container-low': '#1c1b1b',
        'surface-container-lowest': '#0e0e0e',
        'surface-container-high': '#2a2a2a',
        'surface-variant': '#353534',
        'outline-variant': '#51443c',
        outline: '#9e8e84',
        tertiary: '#f0bd8b',
        'tertiary-fixed-dim': '#f0bd8b',
        secondary: '#efbc98',
        'on-secondary': '#48290f',
        'inverse-primary': '#805533',
        'error': '#ffb4ab'
        },
        fontFamily: {
        sans: ['Manrope', 'sans-serif'],
        display: ['Archivo Narrow', 'sans-serif'],
        mono: ['JetBrains Mono', 'monospace']
        }
        }
        }
        }
    </script>

    <style>
        body {
        background-color: #131313;
        color: #e5e2e1;
        font-family: 'Manrope', sans-serif;
        }

        .font-display-lg {
        font-family: 'Archivo Narrow', sans-serif;
        }

        .cinematic-glow {
        box-shadow: inset 0 1px 0 0 rgba(255, 255, 255, 0.1);
        }

        .cinematic-input {
        background-color: transparent;
        border: none;
        border-bottom: 1px solid #51443c;
        transition: all 0.3s ease;
        }
        .cinematic-input:focus {
        outline: none;
        border-bottom: 2px solid #f4bb92;
        background-color: #353534;
        }

        ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
        }
        ::-webkit-scrollbar-track {
        background: #0e0e0e;
        }
        ::-webkit-scrollbar-thumb {
        background: #51443c;
        border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
        background: #8b5e3c;
        }

        .personContainer{
            display: flex;
            flex-direction: column;
        }

        .logoutBtn{
            background-color: #8b5e3c;
            border-radius: 5px;
            padding: 10px 30px;
            font-family: "JetBrains Mono", sans-serif;
            color: #ffe1d1;
            font-size: 12px;
            display: inline-block;
            text-decoration: none;
        }
        .logoutBtn:hover{
            opacity: 0.9;
            cursor: pointer;
        }

    </style>
</head>
<body class="overflow-hidden h-screen select-none">

    <!-- Primary Layout Wrapper -->
    <div class="flex bg-background min-h-screen text-on-surface overflow-hidden relative">

        <!-- Film Grain Texture Overlay -->
        <div class="absolute inset-0 pointer-events-none opacity-[0.03] z-50"
             style="background-image: url('data:image/svg+xml,%3Csvg viewBox=&quot;0 0 200 200&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cfilter id=&quot;noiseFilter&quot;%3E%3CfeTurbulence type=&quot;fractalNoise&quot; baseFrequency=&quot;0.85&quot; numOctaves=&quot;3&quot; stitchTiles=&quot;stitch&quot;/%3E%3C/filter%3E%3Crect width=&quot;100%25&quot; height=&quot;100%25&quot; filter=&quot;url(%23noiseFilter)&quot;/%3E%3C/svg%3E')"></div>

        <!-- Left Sidebar -->
        <aside class="w-64 border-r border-outline-variant/30 bg-surface-container-lowest flex flex-col py-6 relative z-20 hidden md:flex shadow-2xl">
            <div class="px-6 mb-8 flex items-center justify-start border-b border-outline-variant/20 pb-6">
                <div>
                    <h1 class="font-display-lg text-primary tracking-tight text-3xl font-bold uppercase leading-tight">Cosmos</h1>
                    <h1 class="font-display-lg text-primary tracking-tight text-3xl font-bold uppercase leading-tight -mt-2">Cinema</h1>
                </div>
            </div>

            <!-- Navigation Links -->
            <nav class="flex-1 px-4 space-y-2">
                @{
                    var activeNav = ViewBag.ActiveNav as string ?? "home";
                }
                <a href="/Admin"
                   class="flex items-center gap-3 px-4 py-3 rounded-lg mx-2 w-[calc(100%-1rem)] text-left transition-all duration-300 no-underline @(activeNav == "home" ? "bg-primary-container text-on-primary-container cinematic-glow shadow-md" : "text-on-surface-variant hover:text-on-surface hover:bg-surface-variant/30")">
                    <span class="material-symbols-outlined text-[20px]">home</span>
                    <span class="font-mono text-sm font-medium">Trang chủ</span>
                </a>
                <a href="/Admin/Analytics"
                   class="flex items-center gap-3 px-4 py-3 rounded-lg mx-2 w-[calc(100%-1rem)] text-left transition-all duration-300 no-underline @(activeNav == "analytics" ? "bg-primary-container text-on-primary-container cinematic-glow shadow-md" : "text-on-surface-variant hover:text-on-surface hover:bg-surface-variant/30")">
                    <span class="material-symbols-outlined text-[20px]">analytics</span>
                    <span class="font-mono text-sm font-medium">Phân tích doanh thu</span>
                </a>
                <a href="/Admin/Staff"
                   class="flex items-center gap-3 px-4 py-3 rounded-lg mx-2 w-[calc(100%-1rem)] text-left transition-all duration-300 no-underline @(activeNav == "staff" ? "bg-primary-container text-on-primary-container cinematic-glow shadow-md" : "text-on-surface-variant hover:text-on-surface hover:bg-surface-variant/30")">
                    <span class="material-symbols-outlined text-[20px]">badge</span>
                    <span class="font-mono text-sm font-medium">Quản lý nhân viên</span>
                </a>
                <a href="/Admin/Settings"
                   class="flex items-center gap-3 px-4 py-3 rounded-lg mx-2 w-[calc(100%-1rem)] text-left transition-all duration-300 no-underline @(activeNav == "settings" ? "bg-primary-container text-on-primary-container cinematic-glow shadow-md" : "text-on-surface-variant hover:text-on-surface hover:bg-surface-variant/30")">
                    <span class="material-symbols-outlined text-[20px]">settings</span>
                    <span class="font-mono text-sm font-medium">Cài đặt</span>
                </a>
            </nav>

            <!-- Admin Profile -->
            <div class="p-6 border-t border-outline-variant/20 mt-auto">
                <div class="flex items-center gap-2 personContainer">
                    <div class="w-10 h-10 rounded-full bg-surface-container-high flex items-center justify-center border border-outline-variant overflow-hidden">
                        <span class="material-symbols-outlined text-on-surface-variant">person</span>
                    </div>
                    <div>
                        <h4 class="font-mono text-xs text-on-surface font-bold text-sm">System Admin</h4>
                        <p class="font-mono text-[10px] text-on-surface-variant/70">@Context.Session.GetString("UserEmail")</p>
                    </div>
                    <a class="logoutBtn" asp-action="Logout" asp-controller="Account">
                        Đăng xuất 
                    </a>
                </div>
            </div>
        </aside>

        <!-- Main Workspace -->
        <main class="flex-1 h-screen overflow-y-auto relative p-6 md:p-12 z-10 w-full max-w-7xl mx-auto">
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-primary/5 rounded-full blur-[120px] pointer-events-none z-[-1]"></div>

            <!-- Responsive Mobile Header -->
            <header class="flex justify-between items-center mb-12">
                <div class="md:hidden">
                    <h1 class="font-display-lg text-primary tracking-tighter text-3xl font-bold uppercase">Cosmos Cinema</h1>
                </div>
                <div class="hidden md:block"></div>
                <button class="p-2 text-on-surface-variant hover:text-primary transition-colors duration-300 rounded-full hover:bg-surface-container">
                    <span class="material-symbols-outlined">notifications</span>
                </button>
            </header>

            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
