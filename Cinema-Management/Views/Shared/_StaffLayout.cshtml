<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Cosmos Cinema</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Narrow:wght@400;700&family=Manrope:wght@300;400;500;700&family=JetBrains+Mono&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/staff.css" asp-append-version="true"/>

</head>
<body>
<div class="app-shell">
    <aside class="sidebar">
        <div class="sidebar-header">
            <span class="logo-cosmos">COSMOS</span>
            <span class="logo-cinema">CINEMA</span>
        </div>
        <nav class="sidebar-nav">
            <span class="nav-section-title">GIAO DIỆN QUẢN LÝ <br> DÀNH CHO STAFF</span>
            <a asp-controller="Staff" asp-action="Index"
               class="nav-item @(ViewBag.ActiveTab == "scheduling" ? "active" : "")">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                LỊCH CHIẾU PHIM
            </a>
            <a asp-controller="Staff" asp-action="Halls"
               class="nav-item @(ViewBag.ActiveTab == "halls" ? "active" : "")">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14h-14v-4a2 2 0 0 1 2 -2h10a2 2 0 0 1 2 2v4z"></path><path d="M4 14v4a2 2 0 0 0 2 2h12a2 2 0 0 0 2 -2v-4"></path><path d="M3 14h18"></path></svg>
                QUẢN LÝ RẠP CHIẾU
            </a>
            <a asp-controller="Staff" asp-action="Concessions"
               class="nav-item @(ViewBag.ActiveTab == "concessions" ? "active" : "")">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h1a4 4 0 1 1 0 8h-1"></path><path d="M3 8h14v9a4 4 0 0 1 -4 4h-6a4 4 0 0 1 -4 -4z"></path><line x1="6" y1="2" x2="6" y2="4"></line><line x1="10" y1="2" x2="10" y2="4"></line><line x1="14" y1="2" x2="14" y2="4"></line></svg>
                QUẢN LÝ CỬA HÀNG
            </a>
        </nav>
    </aside>
    <div class="main-area">
        @RenderBody()
    </div>
</div>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>