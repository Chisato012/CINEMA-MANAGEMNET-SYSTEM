@{
    ViewData["Title"] = "Kiểm tra email";
    var email = ViewBag.Email as string ?? string.Empty;
}

<head>
    <link rel="stylesheet" href="~/css/auth.css">
</head>

<div class="auth-wrapper">
    <div class="auth-container">
        <div class="text-center">
            <h1 class="auth-header-text fw-bold mb-1">COSMOS CINEMA</h1>
            <p class="auth-subtitle">Hoàn tất xác nhận tài khoản</p>
        </div>

        <div class="auth-card">
            <h2 class="auth-state-title">Kiểm tra email</h2>
            <p class="auth-state-text">
                Đăng ký thành công. Chúng tôi đã gửi liên kết xác nhận tới email của bạn.
            </p>

            @if (!string.IsNullOrWhiteSpace(email))
            {
                <form asp-controller="Account" asp-action="ResendConfirmationEmail" method="post" class="auth-state-form">
                    <input type="hidden" name="email" value="@email" />
                    <button type="submit" class="btn btn-submit w-100">Gửi lại email xác nhận</button>
                </form>
            }

            <a class="auth-secondary-link" asp-controller="Account" asp-action="Login">Quay lại đăng nhập</a>
        </div>
    </div>
</div>
