@{
    ViewData["Title"] = "Đăng nhập";
}

@model Cinema_Management.Models.LoginViewModel

<style>
    .auth-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: calc(100vh - 60px);
        background-color: #121212;
        /* Màu nền Neutral */
        font-family: Jebrains Mono, monospace;
    }

    .auth-container {
        width: 100%;
        max-width: 400px;
    }

    .auth-header-text {
        color: #D4A373;
        /* Màu Tertiary */
        font-family: JetBrains Mono, monospace;
        font-size: 2rem;
        letter-spacing: 1px;
    }

    .auth-subtitle {
        color: #888;
        font-size: 0.85rem;
        margin-bottom: 2rem;
        letter-spacing: 0.5px;
    }

    .auth-card {
        background-color: #1a1a1a;
        border-radius: 8px;
        padding: 2rem;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    }

    .auth-tabs {
        display: flex;
        border-bottom: 1px solid #333;
        margin-bottom: 1.5rem;
    }

    .auth-tab {
        flex: 1;
        text-align: center;
        padding-bottom: 12px;
        color: #888;
        text-decoration: none;
        font-weight: 600;
        font-size: 1rem;
        transition: color 0.3s;
    }

    .auth-tab.active {
        color: #D4A373;
        border-bottom: 2px solid #D4A373;
    }

    .auth-tab:hover:not(.active) {
        color: #bbb;
    }

    .form-label-custom {
        color: #aaa;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        margin-bottom: 0.5rem;
    }

    .forgot-link {
        float: right;
        color: #A67B5B;
        font-size: 0.7rem;
        text-decoration: none;
        letter-spacing: 0.5px;
    }

    .forgot-link:hover {
        color: #D4A373;
    }

    .input-group-custom .input-group-text {
        background-color: #2b2b2b;
        border: 1px solid #2b2b2b;
        color: #888;
        border-right: none;
    }

    .input-group-custom .form-control {
        background-color: #2b2b2b;
        border: 1px solid #2b2b2b;
        color: #ddd;
        border-left: none;
        font-size: 0.9rem;
    }

    .input-group-custom:focus-within .form-control {
        background-color: #2b2b2b;
        color: #fff;
        box-shadow: none;
        border-color: #444;
    }

    .input-group-custom:focus-within .input-group-text {
        border-color: #444;
        color: #D4A373;
        /* Đổi màu icon sang màu nhấn (Vàng/Nâu) cho đẹp, hoặc bạn có thể dùng #fff */
    }

    
    .input-group-custom .input-group-text.end-icon {
        border-left: none;
        border-right: 1px solid #2b2b2b;
        cursor: pointer;
    }


    .form-check-label {
        color: #aaa;
        font-size: 0.8rem;
    }

    .form-check-input {
        background-color: #2b2b2b;
        border-color: #444;
    }



    .form-check-input:checked {
        background-color: #8B5E3C;
        border-color: #8B5E3C;
        border: none;
    }

    .form-check-input:focus {
        box-shadow: 0 0 0 0.2rem rgba(139, 94, 60, 0.5);
    }

    .btn-submit {
        background-color: #8B5E3C;
        /* Màu Primary */
        color: #fff;
        font-weight: 600;
        border: none;
        padding: 0.8rem;
        border-radius: 4px;
        font-size: 0.95rem;
        transition: background-color 0.3s;
    }

    .btn-submit:hover {
        background-color: #A67B5B;
        color: #fff;
    }
</style>

<div class="auth-wrapper">
    <div class="auth-container">
        <!-- Header -->
        <div class="text-center">
            <h1 class="auth-header-text fw-bold mb-1">COSMOS CINEMA</h1>
            <p class="auth-subtitle">Truy cập vũ trụ điện ảnh của bạn</p>
        </div>

        <!-- Form -->
        <div class="auth-card">
            <!-- Tabs -->
            <div class="auth-tabs">
                <a href="#" class="auth-tab active" id="login-tab">Đăng Nhập</a>
                <a class="auth-tab" id="register-tab" href="#">Đăng Ký</a>
            </div>
            <div id="login-container">
                <form asp-controller="Account" asp-action="Login" method="post">
                    <!-- Email Input -->
                    <div class="mb-4">
                        <label class="form-label form-label-custom">ĐỊA CHỈ EMAIL</label>
                        <div class="input-group input-group-custom">
                            <span class="input-group-text">
                                <!-- Mail Icon -->
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                     viewBox="0 0 16 16">
                                    <path
                                    d="M.05 3.555A2 2 0 0 1 2 2h12a2 2 0 0 1 1.95 1.555L8 8.414.05 3.555ZM0 4.697v7.104l5.803-3.558L0 4.697ZM6.761 8.83l-6.57 4.027A2 2 0 0 0 2 14h12a2 2 0 0 0 1.808-1.144l-6.57-4.027L8 9.586l-1.239-.757Zm3.436-.586L16 11.801V4.697l-5.803 3.546Z" />
                                </svg>
                            </span>
                            <input type="email" class="form-control" asp-for="Username"
                                   placeholder="cinephile@example.com" required>
                        </div>
                    </div>

                    <!-- Password Input -->
                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label class="form-label form-label-custom mb-0">MẬT KHẨU</label>
                            <a asp-controller="Account" asp-action="ForgotPassword" class="forgot-link">Quên mật
                                khẩu?</a>
                            </div>
                            <div class="input-group input-group-custom">
                                <span class="input-group-text">
                                    <!-- Lock Icon -->
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                         viewBox="0 0 16 16">
                                        <path
                                        d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2zM5 8h6a1 1 0 0 1 1 1v5a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V9a1 1 0 0 1 1-1z" />
                                    </svg>
                                </span>
                                <input type="password" class="form-control " asp-for="Password" placeholder="••••••••"
                                       required>
                                <span class="input-group-text end-icon">
                                    <!-- Eye Slash Icon -->
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                         viewBox="0 0 16 16">
                                        <path
                                        d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7.028 7.028 0 0 0-2.79.588l.77.771A5.944 5.944 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.134 13.134 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755l.192.195z" />
                                        <path
                                        d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829l.822.822zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829z" />
                                        <path
                                        d="M3.35 5.47c-.18.16-.353.322-.518.487A13.134 13.134 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7.029 7.029 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709zm10.296 8.884-12-12 .708-.708 12 12-.708.708z" />
                                    </svg>
                                </span>
                            </div>

                        </div>

                        <!-- Remember Me -->
                        <div class="mb-4 form-check">
                            <input type="checkbox" class="form-check-input" id="rememberMe" name="rememberMe">
                            <label class="form-check-label" for="rememberMe">Ghi nhớ thiết bị này</label>
                        </div>

                        <!-- Submit Button -->
                        <div class="d-grid mt-2">
                            <button type="submit" class="btn btn-submit">Đăng nhập</button>
                        </div>
                    </form>

                </div>

            <div id="register-container">
                <p class="text-center text-muted">Viết form vào đây (Quang)</p>

                </div> 
            </div>




        </div>
    </div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function(){
            const tabLogin = document.getElementById('login-tab'); // Tab Đăng Nhập
            const tabRegister = document.getElementById('register-tab'); // Tab Đăng Ký
            const loginContainer = document.getElementById('login-container'); // Container Đăng Nhập
            const registerContainer = document.getElementById('register-container'); // Container Đăng Ký

            // Hàm chuyển tab
            tabLogin.addEventListener('click', function(e){
                e.preventDefault();

                //Đổi active tab
                tabLogin.classList.add('active');
                tabRegister.classList.remove('active');

                //Hiển thị form đăng nhập, ẩn form đăng ký
                loginContainer.classList.remove('d-none');
                registerContainer.classList.add('d-none');
            })

            tabRegister.addEventListener('click', function(e){
                e.preventDefault();

                //Đổi active tab
                tabRegister.classList.add('active');
                tabLogin.classList.remove('active');

                //Hiển thị form đăng ký, ẩn form đăng nhập
                registerContainer.classList.remove('d-none');
                loginContainer.classList.add('d-none');
            })
        })
    </script>
}