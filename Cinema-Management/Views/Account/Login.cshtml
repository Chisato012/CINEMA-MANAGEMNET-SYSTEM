@{
    ViewData["Title"] = "Đăng nhập";
}

@model Cinema_Management.Models.LoginRequest
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    var googleLoginEnabled =
        !string.IsNullOrWhiteSpace(Configuration["Authentication:Google:ClientId"]) &&
        !string.IsNullOrWhiteSpace(Configuration["Authentication:Google:ClientSecret"]);
}

<head>
    <link rel="stylesheet" href="~/css/auth.css">
</head>
<div class="auth-wrapper">
    <div class="auth-container">
        <!-- Header -->
        <div class="text-center">
            <h1 class="auth-header-text fw-bold mb-1">COSMOS CINEMA</h1>
            <p class="auth-subtitle">Truy cập vũ trụ điện ảnh của bạn</p>
        </div>

        <!-- Form -->
        <div class="auth-card">
            <!-- Tabs -->
            <div class="auth-tabs">
                <a class="auth-tab active" id="login-tab" asp-controller="Account" asp-action="Login">Đăng Nhập</a>
                @* <a class="auth-tab" id="register-tab" asp-controller="Account" asp-action="Register">Đăng Ký</a> *@
            </div>
            <!-- Login Form -->
            <div id="login-container">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 12px;"></div>
                <form asp-controller="Account" asp-action="Login" method="post">
                    <!-- Email Input -->
                    <div class="mb-4">
                        <label class="form-label form-label-custom">ĐỊA CHỈ EMAIL</label>
                        <div class="input-group input-group-custom">
                            <span class="input-group-text">
                                <!-- Mail Icon -->
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                     viewBox="0 0 16 16">
                                    <path
                                    d="M.05 3.555A2 2 0 0 1 2 2h12a2 2 0 0 1 1.95 1.555L8 8.414.05 3.555ZM0 4.697v7.104l5.803-3.558L0 4.697ZM6.761 8.83l-6.57 4.027A2 2 0 0 0 2 14h12a2 2 0 0 0 1.808-1.144l-6.57-4.027L8 9.586l-1.239-.757Zm3.436-.586L16 11.801V4.697l-5.803 3.546Z" />
                                </svg>
                            </span>
                            <input type="email" id="email-input" class="form-control" asp-for="Email" />

                        </div>
                        <small id="email-error" class="text-danger mt-4"></small>
                        <span asp-validation-for="Email" class="text-danger mt-1" style="font-size: 10px;"></span>
                    </div>

                    <!-- Password Input -->
                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label class="form-label form-label-custom mb-0">MẬT KHẨU</label>
                            <a asp-controller="Account" asp-action="ForgotPassword" class="forgot-link">Quên mật
                                khẩu?</a>
                        </div>
                        <div class="input-group input-group-custom">
                            <span class="input-group-text">
                                    <!-- Lock Icon -->
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                         viewBox="0 0 16 16">
                                        <path
                                        d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2zM5 8h6a1 1 0 0 1 1 1v5a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V9a1 1 0 0 1 1-1z" />
                                </svg>
                            </span>
                            @if (ViewBag.ShowDevelopmentPasswordlessLoginMessage == true)
                            {
                                <input type="password" id="passwordInput" name="Password" class="form-control " value="@Model?.Password">
                            }
                            else
                            {
                                <input type="password" id="passwordInput" class="form-control " asp-for="Password">
                            }
                            <span class="input-group-text end-icon" id="togglePassword">
                                    <!-- Eye Slash Icon -->
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                         viewBox="0 0 16 16">
                                        <path
                                        d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7.028 7.028 0 0 0-2.79.588l.77.771A5.944 5.944 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.134 13.134 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755l.192.195z" />
                                        <path
                                        d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829l.822.822zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829z" />
                                        <path
                                        d="M3.35 5.47c-.18.16-.353.322-.518.487A13.134 13.134 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7.029 7.029 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709zm10.296 8.884-12-12 .708-.708 12 12-.708.708z" />
                                    </svg>
                            </span>
                        </div>
                        <span asp-validation-for="Password" class="text-danger mt-1" style="font-size: 10px;"></span>

                    </div>

                    <div class="mb-3">
                        <div class="cf-turnstile"
                             data-sitekey="@ViewBag.TurnstileSiteKey"
                             data-theme="dark">
                        </div>

                        @if (ViewBag.CaptchaError != null)
                        {
                            <span class="text-danger">@ViewBag.CaptchaError</span>
                        }
                    </div>

                        <!-- Remember Me -->
                    <div class="mb-4 form-check">
                        <input type="checkbox" id="RememberMe" class="form-check-input" asp-for="RememberMe">
                        <label class="form-check-label" for="RememberMe">Ghi nhớ thiết bị này</label>
                    </div>

                    <div class="mb-4" style="font-size: 13px; color:#ccc">
                        <p> <a style="color:#A67B5B" asp-controller="Account" asp-action="Register">Tạo tài khoản</a></p>
                    </div>
                        <!-- Submit Button -->
                    <div class="d-grid mt-2">
                        <button type="submit" class="btn btn-submit">Đăng nhập</button>
                    </div>
                </form>

                @if (ViewBag.UnconfirmedEmail != null)
                {
                    <form asp-controller="Account" asp-action="ResendConfirmationEmail" method="post" class="auth-resend-form">
                        <input type="hidden" name="email" value="@ViewBag.UnconfirmedEmail" />
                        <button type="submit" class="btn-resend-confirmation">Gửi lại email xác nhận</button>
                    </form>
                }

                @* Chi hien nut Google khi da cau hinh du ClientId va ClientSecret. *@
                @if (googleLoginEnabled)
                {
                <div class="auth-divider">
                    <span>Hoặc tiếp tục với</span>
                </div>

                <div class="d-grid">
                    <a id="googleLoginBtn" class="btn btn-google-login" asp-controller="Account" asp-action="GoogleLogin">
                        <svg class="google-logo" viewBox="0 0 48 48" aria-hidden="true">
                            <path fill="#EA4335" d="M24 9.5c3.5 0 6.6 1.2 9 3.6l6.7-6.7C35.6 2.6 30.3.2 24 .2 14.6.2 6.5 5.6 2.6 13.5l7.8 6.1C12.2 13.7 17.7 9.5 24 9.5z" />
                            <path fill="#4285F4" d="M46.5 24.5c0-1.7-.2-3.4-.5-5H24v9.5h12.6c-.5 3-2.2 5.5-4.7 7.2l7.3 5.7c4.3-4 7.3-9.8 7.3-17.4z" />
                            <path fill="#FBBC05" d="M10.4 28.4c-.5-1.4-.8-2.9-.8-4.4s.3-3 .8-4.4l-7.8-6.1C1 16.7.2 20.2.2 24s.8 7.3 2.4 10.5l7.8-6.1z" />
                            <path fill="#34A853" d="M24 47.8c6.3 0 11.6-2.1 15.5-5.8l-7.3-5.7c-2 1.3-4.6 2.1-8.2 2.1-6.3 0-11.8-4.2-13.6-10l-7.8 6.1C6.5 42.4 14.6 47.8 24 47.8z" />
                        </svg>
                        <span>Tiếp tục với Google</span>
                    </a>
                </div>
                }
                </div>

            </div>
        </div>
    </div>

<script src="~/js/auth.js" asp-append-version="true"></script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    @if (googleLoginEnabled)
    {
        <script>
            document.getElementById('googleLoginBtn')?.addEventListener('click', function () {
                const rememberMe = document.getElementById('RememberMe')?.checked || false;
                this.href = '@Url.Action("GoogleLogin", "Account")?rememberMe=' + rememberMe;
            });
        </script>
    }
}

    
    
        

